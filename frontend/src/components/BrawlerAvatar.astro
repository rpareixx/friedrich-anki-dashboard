---
interface Props {
  userSlug: string;
  brawlerSubject: string;
}

const { userSlug, brawlerSubject } = Astro.props;
const src = `/brawler-assets/brawlers/${userSlug}-${brawlerSubject}/common-idle.png`;
---

<img
  src={src}
  alt={`${userSlug} ${brawlerSubject} Brawler`}
  class="h-48 w-48 sm:h-56 sm:w-56 object-contain drop-shadow-2xl"
  loading="eager"
/>
