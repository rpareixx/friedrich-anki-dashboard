---
/**
 * Placeholder-Avatar bis Task 2 (AI-Asset) ein echtes Bild liefert.
 * Wird ersetzt durch <img src="/assets/brawlers/{user}-{subject}/idle.png" />
 * sobald assets/brawlers/{user}-{subject}/idle.png im Repo liegt.
 */
---

<div
  class="relative h-40 w-40 sm:h-48 sm:w-48 rounded-full bg-gradient-to-br from-brawl-accent/40 via-brawl-coin/30 to-brawl-streak/40 flex items-center justify-center shadow-xl shadow-black/40 ring-4 ring-white/10"
  aria-label="Brawler-Avatar (Placeholder)"
>
  <svg
    class="h-24 w-24 text-brawl-bg"
    viewBox="0 0 24 24"
    fill="currentColor"
    aria-hidden="true"
  >
    <path
      d="M12 2.5c-3.04 0-5.5 2.46-5.5 5.5 0 2.31 1.42 4.29 3.43 5.12C6.43 13.96 4 16.7 4 20v.5h16V20c0-3.3-2.43-6.04-5.93-6.88A5.5 5.5 0 0 0 12 2.5z"
    />
  </svg>
  <span
    class="absolute -bottom-2 left-1/2 -translate-x-1/2 pill bg-brawl-bg/90 text-brawl-dim text-[10px] uppercase tracking-widest"
  >
    Placeholder
  </span>
</div>
