---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "friedrich-anki-dashboard" } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="theme-color" content="#0e0c1a" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lilita+One&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <main class="mx-auto max-w-md px-4 py-6 sm:py-10">
      <slot />
    </main>
    <script>
      import Alpine from "alpinejs";
      window.Alpine = Alpine;
      Alpine.start();
    </script>
  </body>
</html>
